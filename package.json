{
  "name": "serial-reader",
  "version": "0.1.2",
  "description": "Desktop app para leitura de equipamentos via porta serial, vinculada a receitas e lotes.",
  "main": "dist/main/main/index.js",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "npm run build:main && concurrently --raw -n MAIN,RENDERER,ELECTRON -c blue,green,yellow \"tsc -p tsconfig.main.json --watch --preserveWatchOutput\" \"vite\" \"npm run dev:electron\"",
    "dev:electron": "wait-on http://localhost:5173 && cross-env ELECTRON_DEV=1 electron . --no-sandbox",
    "electron": "cross-env ELECTRON_DEV=1 electron . --no-sandbox",
    "build": "npm run build:renderer && npm run build:main",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "start": "cross-env NODE_ENV=production ELECTRON_DEV=1 electron . --no-sandbox",
    "prepackage": "npm version patch --no-git-tag-version",
    "package": "npm run build && electron-builder",
    "rebuild": "electron-rebuild -f -w serialport",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "sim:build": "tsc -p tsconfig.tools.json",
    "sim": "npm run sim:build && node dist/tools/serial-sim.js",
    "sim:test": "npm run sim:build && node dist/tools/sim-test.js",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/syne": "^5.2.7",
    "bcryptjs": "^2.4.3",
    "framer-motion": "^12.38.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serialport": "^12.0.0",
    "sql.js": "^1.14.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.2",
    "concurrently": "^9.0.1",
    "cross-env": "^10.1.0",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "playwright-core": "^1.60.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^4.1.6",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.portus.app",
    "productName": "Portus",
    "icon": "build/icon.png",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "certificateFile": null,
      "certificatePassword": null,
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Portus",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico"
    }
  }
}
